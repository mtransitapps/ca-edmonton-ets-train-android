      "color": "4895D0",
      "route_short_name_comment": "21R - BLUE (from PDF map)"
    },
    {
      "route_short_name": "502",
      "color": "DB1E32",
      "route_short_name_comment": "22R - RED (from PDF map)"
    },
    {
      "route_short_name": "503",
      "color": "2B6A3B",
      "route_short_name_comment": "23R - GREEN (from PDF map)"
